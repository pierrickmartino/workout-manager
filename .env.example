# Copy to .env and fill in before `docker compose up`.
# These are consumed by docker-compose.yml and passed into the api/web services.

# --- Clerk (https://dashboard.clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# The "iss" of your Clerk session tokens and its JWKS endpoint.
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# --- AI generation provider (ADR-0006) ---
# AI_PROVIDER selects the generation provider per deployment. Only `anthropic`
# is wired today; the other slots are reserved. Only the *selected* provider's
# key is required at startup — the app fails fast if it's missing. Keys for
# unselected providers may be left blank.
AI_PROVIDER=anthropic

# Per-provider API keys. Set the one matching AI_PROVIDER.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Optional: override the selected provider's default model
# (anthropic -> claude-opus-4-8). Leave blank to use the default.
AI_MODEL=

# --- Host port overrides (optional) ---
# Only the host side of each mapping; containers keep their standard ports and
# talk to each other over the compose network regardless. Override any that
# clash with something already running locally, e.g. DB_PORT=5433.
# DB_PORT=5432
# REDIS_PORT=6379
# API_PORT=8000
# WEB_PORT=3000