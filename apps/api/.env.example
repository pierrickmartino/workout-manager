# Clerk JWT verification. From your Clerk dashboard (API keys / "Show JWT public key"):
#   CLERK_ISSUER     = the "iss" of your Clerk session tokens
#                      (e.g. https://your-app.clerk.accounts.dev)
#   CLERK_JWKS_URL   = {issuer}/.well-known/jwks.json
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Postgres (psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/workout

# Redis (generation cache + RQ job queue in later slices).
REDIS_URL=redis://localhost:6379/0

# AI generation provider (ADR-0006). AI_PROVIDER selects the provider per
# deployment; only `anthropic` is wired today. Only the selected provider's key
# is required at startup (the app fails fast if it's missing); keys for
# unselected providers may be blank. AI_MODEL optionally overrides the selected
# provider's default model (anthropic -> claude-opus-4-8).
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
AI_MODEL=
